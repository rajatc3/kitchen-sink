{
  "id": "kitchensink",
  "realm": "kitchensink",
  "enabled": true,
  "clients": [
    {
      "clientId": "kitchensink-client",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:8081/login/oauth2/code/keycloak"
